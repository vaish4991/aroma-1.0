        subgraph NLP ["Multi-Model NLP Pipeline"]
            VADER[VADER Sentiment]
            TB[TextBlob Analyzer]
            AFINN[AFINN Scorer]
            ENS[Ensemble Voter]
            EMO[GoEmotions Classifier]
        end
        
        subgraph RAG ["Knowledge Retrieval"]
            KB[Knowledge Base JSON]
            SIM[TF-IDF Similarity Search]
            CTX[Context Builder]
        end
        
        subgraph LLM ["Response Generation"]
            GPT[GPT-4o API]
            FALL[Multi-tier Fallback]
            TRN[Trained Templates - 500+]
        end
    end
    
    subgraph Data ["Training Data (Kaggle/IEEE)"]
        D1[EmpatheticDialogues]
        D2[GoEmotions - Google]
        D3[Counsel Chat]
        D4[Mental Health FAQ]
        D5[DailyDialog]
        D6[Emotion Dataset - IEEE]
    end
    
    UI --> API
    API --> NLP
    NLP --> RAG
    RAG --> LLM
    LLM --> API
    Data --> KB
    Data --> TRN
```

